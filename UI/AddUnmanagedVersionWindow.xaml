<Window x:Class="SubnauticaLauncher.UI.AddUnmanagedVersionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Add Unmanaged Version"
        Width="470"
        Height="450"
        MinWidth="470"
        MinHeight="450"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="{DynamicResource AppFontFamily}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <ImageBrush x:Key="BackgroundBrush"
                    Stretch="UniformToFill"/>

        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D0E7F2"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="25"
            ResizeBorderThickness="6"
            CornerRadius="0"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Rectangle Fill="{StaticResource BackgroundBrush}">
            <Rectangle.Effect>
                <BlurEffect Radius="8"/>
            </Rectangle.Effect>
        </Rectangle>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#40000000"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Source="pack://application:,,,/Assets/Icons/SNLIcon.png"
                       Width="16"
                       Height="16"
                       Margin="12,0,8,0"
                       VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="Add Unmanaged Version"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Margin="0,3,0,0"
                           FontWeight="SemiBold"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">

                    <Button Content="&#x2014;"
                            Width="44"
                            Height="25"
                            Background="Transparent"
                            BorderBrush="#55000000"
                            BorderThickness="1"
                            Click="Minimize_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <Button Content="&#x25A1;"
                            Width="44"
                            Height="25"
                            Background="Transparent"
                            BorderBrush="#55000000"
                            BorderThickness="1"
                            Click="Maximize_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <Button Content="&#x2715;"
                            Width="44"
                            Height="25"
                            Background="#8B2C2C"
                            BorderBrush="#55000000"
                            BorderThickness="1"
                            Click="Close_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Background="#66000000"
                    BorderBrush="#99000000"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14"
                    Margin="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Add Existing Version"
                               FontWeight="UltraBold"
                               FontSize="20"
                               Margin="0,0,0,12"/>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Folder (Must Contain Game Executable)"
                                   FontWeight="Heavy"
                                   FontSize="14"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,4"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="FolderPathBox"
                                     IsReadOnly="True"/>

                            <Button Content="Browse"
                                    Width="92"
                                    Margin="8,0,0,0"
                                    Grid.Column="1"
                                    Background="{StaticResource DialogNeutralButtonBrush}"
                                    Style="{StaticResource RoundedButton}"
                                    Click="Browse_Click"/>
                        </Grid>

                        <TextBlock Text="Display Name"
                                   FontWeight="Heavy"
                                   FontSize="14"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,4"/>

                        <TextBox x:Name="DisplayNameBox"
                                 MaxLength="25"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Folder Name"
                                   FontWeight="Heavy"
                                   FontSize="14"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,4"/>

                        <TextBox x:Name="FolderNameBox"
                                 Margin="0,0,0,8"/>

                        <TextBlock Text="Detected Original Version"
                                   FontWeight="Heavy"
                                   FontSize="14"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,4"/>

                        <Border Background="#22000000"
                                BorderBrush="White"
                                BorderThickness="1"
                                Padding="8"
                                Margin="0,0,0,6">
                            <TextBlock x:Name="DetectedOriginalVersionText"
                                       Text="Select a valid game folder to auto-detect the version."
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">

                        <Button x:Name="AddButton"
                                Content="Add"
                                Width="112"
                                Margin="0,0,12,0"
                                Background="#FF4FD38B"
                                Style="{StaticResource RoundedButton}"
                                Click="Add_Click"/>

                        <Button Content="Cancel"
                                Width="112"
                                Background="#8B2C2C"
                                Style="{StaticResource RoundedButton}"
                                Click="Cancel_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>





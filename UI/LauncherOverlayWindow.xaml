<Window x:Class="SubnauticaLauncher.UI.LauncherOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SubnauticaLauncher.Converters"
        Title="Subnautica Launcher Overlay"
        Width="1280"
        Height="720"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:ActiveColorConverter x:Key="ActiveColorConverter"/>
        <converters:StringLengthToFontSizeConverter x:Key="StringLengthToFontSizeConverter"/>
        <SolidColorBrush x:Key="OverlayMainShellButtonBrush" Color="#E1192236"/>
        <SolidColorBrush x:Key="OverlayVersionListCardBrush" Color="#C4121826"/>
        <SolidColorBrush x:Key="OverlayLaunchAccentBrush" Color="#C951D68F"/>
        <SolidColorBrush x:Key="OverlayAccentBlueBrush" Color="#C83D76D4"/>

        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="OverlayToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#E1192236"/>
            <Setter Property="BorderBrush" Value="#7298C8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="OverlayPanelButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource OverlayMainShellButtonBrush}"/>
            <Setter Property="BorderBrush" Value="#7298C8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="OverlayPanelIconButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="BorderBrush" Value="#7096C8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="OverlayReadOnlyTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{StaticResource ReadOnlyInputForegroundBrush}"/>
            <Setter Property="Background" Value="#C8111623"/>
            <Setter Property="BorderBrush" Value="#88A0C6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="OverlayEditableTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource OverlayReadOnlyTextBoxStyle}">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="OverlayComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource OverlayDarkComboBox}">
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style x:Key="OverlayVersionListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource VersionListItemStyle}"/>

        <Style x:Key="OverlayVersionRowIconButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#8FA5C9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#F3F8FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconBorder"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#D7E5FF"/>
                                <Setter TargetName="IconBorder" Property="Background" Value="#14FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#EAF4FF"/>
                                <Setter TargetName="IconBorder" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="IconBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="OverlayVersionRowFolderIconTemplate">
            <Viewbox Width="12" Height="12" Stretch="Uniform">
                <Canvas Width="16" Height="16">
                    <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.4"
                          StrokeLineJoin="Round"
                          Data="M1.7,5.2 L5.8,5.2 L7.1,3.7 L14.1,3.7 C14.8,3.7 15.3,4.2 15.3,4.9 L15.3,12.6 C15.3,13.3 14.8,13.8 14.1,13.8 L1.9,13.8 C1.2,13.8 0.7,13.3 0.7,12.6 L0.7,6.4 C0.7,5.7 1.2,5.2 1.9,5.2 Z"/>
                </Canvas>
            </Viewbox>
        </DataTemplate>

        <DataTemplate x:Key="OverlayVersionRowCogIconTemplate">
            <Viewbox Width="12" Height="12" Stretch="Uniform">
                <Canvas Width="16" Height="16">
                    <Path Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          Data="M6.9,0.9 L9.1,0.9 L9.5,2.5 C10,2.7 10.4,2.9 10.8,3.2 L12.3,2.4 L13.9,4.0 L13.1,5.5 C13.4,5.9 13.6,6.3 13.8,6.8 L15.4,7.2 L15.4,9.4 L13.8,9.8 C13.6,10.3 13.4,10.7 13.1,11.1 L13.9,12.6 L12.3,14.2 L10.8,13.4 C10.4,13.7 10,13.9 9.5,14.1 L9.1,15.7 L6.9,15.7 L6.5,14.1 C6,13.9 5.6,13.7 5.2,13.4 L3.7,14.2 L2.1,12.6 L2.9,11.1 C2.6,10.7 2.4,10.3 2.2,9.8 L0.6,9.4 L0.6,7.2 L2.2,6.8 C2.4,6.3 2.6,5.9 2.9,5.5 L2.1,4.0 L3.7,2.4 L5.2,3.2 C5.6,2.9 6,2.7 6.5,2.5 Z M8.0,5.2 C6.5,5.2 5.2,6.5 5.2,8.0 C5.2,9.5 6.5,10.8 8.0,10.8 C9.5,10.8 10.8,9.5 10.8,8.0 C10.8,6.5 9.5,5.2 8.0,5.2 Z"/>
                </Canvas>
            </Viewbox>
        </DataTemplate>

        <DataTemplate x:Key="OverlayVersionHeaderTemplate">
            <TextBlock Text="{Binding Name}"
                       Margin="6,8,6,4"
                       FontSize="15"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="White"/>
        </DataTemplate>

        <DataTemplate x:Key="OverlayVersionRowTemplate">
            <Grid Margin="4,2"
                  Tag="{Binding}"
                  MouseLeftButtonDown="OverlayVersionRow_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="58"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="6,4,10,4"
                        ClipToBounds="True">
                    <TextBlock Text="{Binding DisplayLabel}"
                               FontSize="{Binding DisplayLabel, Converter={StaticResource StringLengthToFontSizeConverter}}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               VerticalAlignment="Center"
                               Foreground="{Binding Status, Converter={StaticResource ActiveColorConverter}}"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Tag="{Binding}"
                            ToolTip="Open Folder"
                            ContentTemplate="{StaticResource OverlayVersionRowFolderIconTemplate}"
                            Style="{StaticResource OverlayVersionRowIconButtonStyle}"
                            Click="OpenOverlayVersionFolder_Click"/>

                    <Button Tag="{Binding}"
                            ToolTip="Edit Version"
                            ContentTemplate="{StaticResource OverlayVersionRowCogIconTemplate}"
                            Style="{StaticResource OverlayVersionRowIconButtonStyle}"
                            Click="EditOverlayVersion_Click"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          Focusable="True"
          Background="Transparent"
          MouseMove="RootGrid_MouseMove"
          MouseLeftButtonUp="RootGrid_MouseLeftButtonUp">
        <Canvas x:Name="OverlayCanvas"
                Background="Transparent"/>

        <Border x:Name="TopBarBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,20,0,0"
                Padding="10,8"
                CornerRadius="16"
                Background="#E2141C30"
                BorderBrush="#7F97C5"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="AddComponentButton"
                        Grid.Column="0"
                        Style="{StaticResource OverlayToolbarButtonStyle}"
                        Content="&#9776;"
                        Click="AddComponentButton_Click"/>

                <Button x:Name="OverlaySettingsButton"
                        Grid.Column="2"
                        Style="{StaticResource OverlayToolbarButtonStyle}"
                        Content="&#9881;"
                        Click="OverlaySettingsButton_Click"/>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Selected Version: "
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="SelectedVersionValueText"
                               FontSize="13"
                               FontWeight="Bold"
                               Text="None"/>
                </StackPanel>

                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Active Version: "
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="ActiveVersionValueText"
                               FontSize="13"
                               FontWeight="Bold"
                               Text="None"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

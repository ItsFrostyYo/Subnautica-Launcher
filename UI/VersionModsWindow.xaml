<Window x:Class="SubnauticaLauncher.UI.VersionModsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Version Mods"
        Width="420"
        Height="240"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="{DynamicResource AppFontFamily}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <ImageBrush x:Key="BackgroundBrush" Stretch="UniformToFill"/>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="28"
            ResizeBorderThickness="0"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Rectangle Fill="{StaticResource BackgroundBrush}">
            <Rectangle.Effect>
                <BlurEffect Radius="8"/>
            </Rectangle.Effect>
        </Rectangle>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#40000000"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Text="Version Mods"/>

                <Button Grid.Column="1"
                        Content="&#x2715;"
                        Width="44"
                        Height="28"
                        Margin="4,0,4,0"
                        Background="#8B2C2C"
                        BorderThickness="0"
                        Click="Close_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>

            <Border Grid.Row="1"
                    Background="#90000000"
                    CornerRadius="14"
                    Padding="18"
                    Margin="18">
                <StackPanel>
                    <TextBlock x:Name="StatusText"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="DescriptionText"
                               TextWrapping="Wrap"
                               Foreground="#D0E7F2"
                               Margin="0,0,0,18"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button x:Name="RemoveModsButton"
                                Content="Remove Mods"
                                Width="140"
                                Margin="0,0,12,0"
                                Background="#8B2C2C"
                                Style="{StaticResource RoundedButton}"
                                Click="RemoveMods_Click"/>

                        <Button Content="Close"
                                Width="110"
                                Background="{StaticResource DialogNeutralButtonBrush}"
                                Style="{StaticResource RoundedButton}"
                                Click="Cancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

<Window x:Class="SubnauticaLauncher.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SubnauticaLauncher.Converters"
        xmlns:ui="clr-namespace:SubnauticaLauncher.UI"
        xmlns:updates="clr-namespace:SubnauticaLauncher.Updates"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Subnautica Launcher"
        Width="1000"
        Height="550"
        MinWidth="1000"
        MinHeight="550"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="{DynamicResource AppFontFamily}"
        WindowStyle="None"
        AllowsTransparency="True">

    <!-- ================= BACKGROUND ================= -->
    <Window.Background>
        <ImageBrush x:Name="BackgroundBrush"
                    Stretch="UniformToFill"/>
    </Window.Background>

    <!-- ================= RESOURCES ================= -->
    <Window.Resources>

        <converters:ActiveColorConverter x:Key="ActiveColorConverter"/>
        <converters:StringLengthToFontSizeConverter x:Key="StringLengthToFontSizeConverter"/>

        <SolidColorBrush x:Key="MainShellPanelBrush" Color="#C6141C2C"/>
        <SolidColorBrush x:Key="MainShellBorderBrush" Color="#6D88A8"/>
        <SolidColorBrush x:Key="WindowTitleBarBrush" Color="#90000000"/>
        <SolidColorBrush x:Key="MainShellSidebarBrush" Color="#90000000"/>
        <SolidColorBrush x:Key="MainShellSidebarTextBrush" Color="#F4F8FF"/>
        <SolidColorBrush x:Key="MainShellSidebarMutedBrush" Color="#AEBBD6"/>
        <SolidColorBrush x:Key="MainShellSidebarHoverBrush" Color="#663AA8FF"/>
        <SolidColorBrush x:Key="MainShellSidebarActiveBrush" Color="#661A6F3C"/>
        <SolidColorBrush x:Key="MainShellButtonBrush" Color="#C81A2337"/>
        <SolidColorBrush x:Key="MainShellButtonHoverBrush" Color="#D32A3C58"/>
        <SolidColorBrush x:Key="MainShellPrimaryHoverBrush" Color="#63BBFF"/>
        <SolidColorBrush x:Key="MainShellButtonBorderBrush" Color="#7C95BD"/>

        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="214"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MainShellSidebarTextBrush}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="22,11"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource MainShellSidebarHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource MainShellSidebarActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="NavBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource MainShellSidebarActiveBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Active"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource MainShellSidebarActiveBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PrimaryButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <Grid>
                                <Border x:Name="PrimaryHoverOverlay"
                                        Background="#00FFFFFF"
                                        CornerRadius="12"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PrimaryHoverOverlay" Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PrimaryHoverOverlay" Property="Background" Value="#28FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PrimaryButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.015" ScaleY="1.015"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
            <Setter Property="Background" Value="{StaticResource MainShellButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource MainShellButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SecondaryButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <Border x:Name="SecondaryHoverOverlay"
                                        Background="#00FFFFFF"
                                        CornerRadius="11"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SecondaryHoverOverlay" Property="Background" Value="#16FFFFFF"/>
                                <Setter TargetName="SecondaryButtonBorder" Property="BorderBrush" Value="#A9BEDD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SecondaryHoverOverlay" Property="Background" Value="#24FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SecondaryButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.012" ScaleY="1.012"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="ToggleActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SidebarLaunchButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource LaunchAccentBrush}"/>
            <Setter Property="BorderBrush" Value="#A8E5C6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <Style x:Key="RoundedButton" TargetType="Button" BasedOn="{StaticResource SmallActionButtonStyle}">
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="VersionListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="VersionRowIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#8FA5C9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#F3F8FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconBorder"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#D7E5FF"/>
                                <Setter TargetName="IconBorder" Property="Background" Value="#14FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#EAF4FF"/>
                                <Setter TargetName="IconBorder" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="IconBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="VersionRowFolderIconTemplate">
            <Viewbox Width="12" Height="12" Stretch="Uniform">
                <Canvas Width="16" Height="16">
                    <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.4"
                          StrokeLineJoin="Round"
                          Data="M1.7,5.2 L5.8,5.2 L7.1,3.7 L14.1,3.7 C14.8,3.7 15.3,4.2 15.3,4.9 L15.3,12.6 C15.3,13.3 14.8,13.8 14.1,13.8 L1.9,13.8 C1.2,13.8 0.7,13.3 0.7,12.6 L0.7,6.4 C0.7,5.7 1.2,5.2 1.9,5.2 Z"/>
                </Canvas>
            </Viewbox>
        </DataTemplate>

        <DataTemplate x:Key="VersionRowCogIconTemplate">
            <Viewbox Width="12" Height="12" Stretch="Uniform">
                <Canvas Width="16" Height="16">
                    <Path Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          Data="M6.9,0.9 L9.1,0.9 L9.5,2.5 C10,2.7 10.4,2.9 10.8,3.2 L12.3,2.4 L13.9,4.0 L13.1,5.5 C13.4,5.9 13.6,6.3 13.8,6.8 L15.4,7.2 L15.4,9.4 L13.8,9.8 C13.6,10.3 13.4,10.7 13.1,11.1 L13.9,12.6 L12.3,14.2 L10.8,13.4 C10.4,13.7 10,13.9 9.5,14.1 L9.1,15.7 L6.9,15.7 L6.5,14.1 C6,13.9 5.6,13.7 5.2,13.4 L3.7,14.2 L2.1,12.6 L2.9,11.1 C2.6,10.7 2.4,10.3 2.2,9.8 L0.6,9.4 L0.6,7.2 L2.2,6.8 C2.4,6.3 2.6,5.9 2.9,5.5 L2.1,4.0 L3.7,2.4 L5.2,3.2 C5.6,2.9 6,2.7 6.5,2.5 Z M8.0,5.2 C6.5,5.2 5.2,6.5 5.2,8.0 C5.2,9.5 6.5,10.8 8.0,10.8 C9.5,10.8 10.8,9.5 10.8,8.0 C10.8,6.5 9.5,5.2 8.0,5.2 Z"/>
                </Canvas>
            </Viewbox>
        </DataTemplate>

    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
CaptionHeight="25"
ResizeBorderThickness="6"
CornerRadius="0"
GlassFrameThickness="0"
UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <!-- ================= ROOT ================= -->
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <!-- TITLE BAR -->
            <RowDefinition Height="*"/>
            <!-- CONTENT -->
        </Grid.RowDefinitions>

        <!-- ================= CUSTOM TITLE BAR ================= -->
        <Grid Grid.Row="0"
      Background="{StaticResource WindowTitleBarBrush}"
      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Icon -->
                <ColumnDefinition Width="Auto"/>
                <!-- Title -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <!-- Window buttons -->
            </Grid.ColumnDefinitions>

            <!-- ICON -->
            <Image Grid.Column="0"
           Source="pack://application:,,,/Assets/Icons/SNLIcon.png"
           Width="16"
           Height="16"
           Margin="12,0,8,0"
           VerticalAlignment="Center"/>

            <!-- TITLE -->
            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center">
                <TextBlock Text="Subnautica + Below Zero Launcher"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,6,0"/>
                <TextBlock Text="{x:Static updates:Updates.DisplayVersion}"
                   FontSize="13"
                   Opacity="0.7"/>
            </StackPanel>

            <!-- WINDOW BUTTONS -->
            <StackPanel Grid.Column="3"
                Orientation="Horizontal">

                <Button Content="&#x2014;"
                Width="44"
                Height="25"
                Background="Transparent"
                BorderBrush="{StaticResource WindowButtonBorderBrush}"
                BorderThickness="1"
                Click="Minimize_Click"
                AutomationProperties.Name="Minimize Window"
                ToolTip="Minimize"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                <Button Content="&#x25A1;"
                Width="44"
                Height="25"
                Background="Transparent"
                BorderBrush="{StaticResource WindowButtonBorderBrush}"
                BorderThickness="1"
                Click="Maximize_Click"
                AutomationProperties.Name="Maximize Window"
                ToolTip="Maximize or Restore"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                <Button Content="&#x2715;"
                Width="44"
                Height="25"
                Background="{StaticResource DangerRedBrush}"
                BorderBrush="{StaticResource WindowButtonBorderBrush}"
                BorderThickness="1"
                Click="Close_Click"
                AutomationProperties.Name="Close Window"
                ToolTip="Close Launcher"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </StackPanel>
        </Grid>

        <!-- ================= CONTENT ================= -->
        <Viewbox Grid.Row="1"
                 Stretch="Uniform"
                 StretchDirection="UpOnly">

            <Border Padding="0">

                <Grid Width="1000"
                      Height="525"
                      Margin="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="266"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ================= LEFT SIDEBAR ================= -->
                    <Border Grid.Column="0"
                            Margin="0"
                            Background="{StaticResource MainShellSidebarBrush}"
                            CornerRadius="0">
                        <Grid Margin="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Margin="6,10,4,0">
                                <TextBlock Text="NAVIGATION"
                                           Margin="8,0,0,12"
                                           FontSize="10"
                                           Foreground="{StaticResource MainShellSidebarMutedBrush}"/>

                                <Button x:Name="PlayNavButton"
                                        Content="Play"
                                        Style="{StaticResource SidebarNavButtonStyle}"
                                        Click="InstallsTab_Click"/>

                                <Button x:Name="SettingsNavButton"
                                        Content="Settings"
                                        Style="{StaticResource SidebarNavButtonStyle}"
                                        Click="SettingsTab_Click"/>

                                <Button x:Name="ToolsNavButton"
                                        Content="Tools"
                                        Style="{StaticResource SidebarNavButtonStyle}"
                                        Click="ToolsTab_Click"/>

                                <Button x:Name="LauncherInfoNavButton"
                                        Content="Launcher Info"
                                        Style="{StaticResource SidebarNavButtonStyle}"
                                        Click="InfoTab_Click"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Margin="6,18,4,6">
                                <TextBlock Text="SELECTED VERSION"
                                           FontSize="11"
                                           Foreground="{StaticResource MainShellSidebarMutedBrush}"/>
                                <Grid Margin="0,10,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="SidebarSelectionTextBlock"
                                               Margin="0,0,10,0"
                                               FontSize="12"
                                               Foreground="{StaticResource MainShellSidebarTextBrush}"
                                               Text="Select a version to enable launch."
                                               TextWrapping="Wrap"/>

                                    <Button x:Name="SwitchButton"
                                            Grid.Column="1"
                                            Content="Switch"
                                            Width="76"
                                            Height="34"
                                            VerticalAlignment="Top"
                                            Background="{StaticResource MainShellButtonBrush}"
                                            Style="{StaticResource RoundedButton}"
                                            Click="SwitchButton_Click"/>
                                </Grid>

                                <TextBlock Text="VERSION STATUS"
                                           FontSize="11"
                                           Foreground="{StaticResource MainShellSidebarMutedBrush}"/>
                                <TextBlock x:Name="SidebarStatusTextBlock"
                                           Margin="0,10,0,14"
                                           FontSize="12"
                                           Foreground="{StaticResource MainShellSidebarTextBrush}"
                                           Text="No game activity."
                                           TextWrapping="Wrap"/>

                                <Button x:Name="LaunchButton"
                                        Content="Launch"
                                        Width="192"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource LaunchAccentBrush}"
                                        Style="{StaticResource SidebarLaunchButtonStyle}"
                                        Click="Launch_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ================= CONTENT ================= -->
                    <Grid Grid.Column="1"
                          Margin="18">

                        <!-- ===== INSTALLS VIEW ===== -->
                        <Grid x:Name="InstallsView" Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="58"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,8,10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Subnautica"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                        Content="Install Version"
                                        Width="138"
                                        Height="36"
                                        Margin="0,0,0,0"
                                        Background="{StaticResource MainShellButtonBrush}"
                                        Style="{StaticResource RoundedButton}"
                                        Click="InstallVersion_Click"/>

                                <TextBlock Grid.Column="3"
                                           Text="Below Zero"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,10,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{StaticResource VersionListCardBrush}"
                                        CornerRadius="14"
                                        Padding="6">
                                    <ListBox x:Name="InstalledVersionsList"
                                             FontSize="17"
                                             Margin="0"
                                             FontWeight="UltraLight"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             HorizontalContentAlignment="Stretch"
                                             ItemContainerStyle="{StaticResource VersionListItemStyle}"
                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                             SelectionChanged="InstalledVersionsList_SelectionChanged">
                                        <ListBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Margin="6,8,6,4"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="White"/>
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ListBox.GroupStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="4,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="58"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Margin="6,4,10,4"
                                                            ClipToBounds="True">
                                                        <TextBlock Text="{Binding DisplayLabel}"
                                                                   FontSize="{Binding DisplayLabel, Converter={StaticResource StringLengthToFontSizeConverter}}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding Status, Converter={StaticResource ActiveColorConverter}}"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center">
                                                        <Button Tag="{Binding}"
                                                                ToolTip="Open Folder"
                                                                ContentTemplate="{StaticResource VersionRowFolderIconTemplate}"
                                                                Style="{StaticResource VersionRowIconButtonStyle}"
                                                                Click="OpenVersionFolderRow_Click"/>

                                                        <Button Tag="{Binding}"
                                                                ToolTip="Edit Version"
                                                                ContentTemplate="{StaticResource VersionRowCogIconTemplate}"
                                                                Style="{StaticResource VersionRowIconButtonStyle}"
                                                                Click="EditVersionRow_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="{StaticResource VersionListCardBrush}"
                                        CornerRadius="14"
                                        Padding="6">
                                    <ListBox x:Name="BZInstalledVersionsList"
                                             FontSize="17"
                                             Margin="0"
                                             FontWeight="UltraLight"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             HorizontalContentAlignment="Stretch"
                                             ItemContainerStyle="{StaticResource VersionListItemStyle}"
                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                             SelectionChanged="BZInstalledVersionsList_SelectionChanged">
                                        <ListBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Margin="6,8,6,4"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="White"/>
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ListBox.GroupStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="4,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="58"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Margin="6,4,10,4"
                                                            ClipToBounds="True">
                                                        <TextBlock Text="{Binding DisplayLabel}"
                                                                   FontSize="{Binding DisplayLabel, Converter={StaticResource StringLengthToFontSizeConverter}}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding Status, Converter={StaticResource ActiveColorConverter}}"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center">
                                                        <Button Tag="{Binding}"
                                                                ToolTip="Open Folder"
                                                                ContentTemplate="{StaticResource VersionRowFolderIconTemplate}"
                                                                Style="{StaticResource VersionRowIconButtonStyle}"
                                                                Click="OpenVersionFolderRow_Click"/>

                                                        <Button Tag="{Binding}"
                                                                ToolTip="Edit Version"
                                                                ContentTemplate="{StaticResource VersionRowCogIconTemplate}"
                                                                Style="{StaticResource VersionRowIconButtonStyle}"
                                                                Click="EditVersionRow_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0">
                            </StackPanel>
                        </Grid>

                        <!-- ===== SETTINGS VIEW ===== -->
                        <Grid x:Name="SettingsView"
      Visibility="Collapsed"
      Margin="24">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ================= LEFT: CUSTOMIZE ================= -->
                            <Border Grid.Column="0"
            Margin="0,0,12,0"
            Background="{StaticResource StrongPanelBackgroundBrush}"
            CornerRadius="12"
            Padding="16">

                                <StackPanel>
                                    <TextBlock Text="Customize"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

                                    <TextBlock Text="Background"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>

                                    <ComboBox x:Name="ThemeDropdown"
                      Style="{StaticResource MainDarkComboBox}"
                      SelectionChanged="ThemeDropdown_SelectionChanged">

                                        <ComboBoxItem Content="Lifepod"/>
                                        <ComboBoxItem Content="Safe Shallows"/>
                                        <ComboBoxItem Content="Kelp Forest"/>
                                        <ComboBoxItem Content="Grassy Plateau"/>
                                        <ComboBoxItem Content="Lost River"/>
                                        <ComboBoxItem Content="Cove Tree"/>
                                        <ComboBoxItem Content="Floating Island"/>
                                        <ComboBoxItem Content="Jellyshroom Caves"/>
                                        <ComboBoxItem Content="Grand Reef"/>
                                        <ComboBoxItem Content="Reaper Leviathan"/>
                                        <ComboBoxItem Content="Ghost Leviathan"/>
                                        <ComboBoxItem Content="Sea Dragon Leviathan"/>
                                        <ComboBoxItem Content="Twisty Bridges"/>
                                        <ComboBoxItem Content="Aurora Borealis"/>
                                        <ComboBoxItem Content="Snowfox"/>
                                        <ComboBoxItem Content="Icy Land"/>
                                        <ComboBoxItem Content="Arcitect Facility"/>
                                        <ComboBoxItem Content="Red Crystals"/>
                                        <ComboBoxItem Content="Snow Stalker"/>
                                        <ComboBoxItem Content="Squid Shark"/>
                                        <ComboBoxItem Content="Shadow Leviathan"/>
                                        <ComboBoxItem Content="Custom"/>
                                    </ComboBox>

                                    <Button Content="Choose Custom Background"
                    Width="270"                    
                    Height="35"
                    FontSize="15"
                    Margin="-5,15,-5,0"
                    Background="{StaticResource MainShellButtonBrush}"
                    Style="{StaticResource RoundedButton}"
                    Click="ChooseCustomBackground_Click"/>

                                    <Border Height="1"
                                            Background="{StaticResource SoftDividerBrush}"
                                            Margin="0,14,0,10"/>

                                    <TextBlock Text="Overlay Transparency"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Slider x:Name="OverlayOpacitySlider"
                                                Minimum="0"
                                                Maximum="1"
                                                Value="0.5"
                                                TickFrequency="0.05"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="OverlayOpacitySlider_ValueChanged"/>
                                        <TextBlock x:Name="OverlayOpacityText"
                                                   Grid.Column="1"
                                                   Width="56"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   Text="50%"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ================= RIGHT: OPTIONS ================= -->
                            <Border Grid.Column="1"
        Margin="12,0,0,0"
        Background="{StaticResource PanelBackgroundBrush}"
        CornerRadius="12"
        Padding="16">

                                <StackPanel>
                                    <TextBlock Text="Options"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,12"/>

                                    <!-- EXPLOSION RESET DISPLAY -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
Text="Explosion Overlay"
VerticalAlignment="Center"
FontWeight="SemiBold"/>

                                        <Button
x:Name="ExplosionDisplayToggleButton"
Grid.Column="1"
Width="138"
Height="38"
Background="{StaticResource DangerRedBrush}"
Content="Disabled"
Style="{StaticResource ToggleActionButtonStyle}"
Click="ExplosionDisplayToggle_Click"/>
                                    </Grid>

                                    <!-- TRACK EXPLOSION RESETS -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
Text="Track Explo Resets"
VerticalAlignment="Center"
FontWeight="SemiBold"/>

                                        <Button
x:Name="ExplosionTrackToggleButton"
Grid.Column="1"
Width="138"
Height="38"
Background="{StaticResource DangerRedBrush}"
Content="Disabled"
Style="{StaticResource ToggleActionButtonStyle}"
Click="ExplosionTrackToggle_Click"/>
                                    </Grid>

                                    <Border Height="1"
                                            Background="{StaticResource SoftDividerBrush}"
                                            Margin="0,12,0,10"/>

                                    <TextBlock Text="Launcher Startup Mode"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>

                                    <ComboBox x:Name="StartupModeDropdown"
                                              Style="{StaticResource MainDarkComboBox}"
                                              SelectionChanged="StartupModeDropdown_SelectionChanged">
                                        <ComboBoxItem Content="Startup as Window"/>
                                        <ComboBoxItem Content="Startup as Overlay"/>
                                    </ComboBox>

                                    <TextBlock Text="Overlay Toggle Hotkey"
                                               FontWeight="SemiBold"
                                               Margin="0,10,0,4"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="OverlayHotkeyBox"
                                                 Height="32"
                                                 IsReadOnly="True"
                                                 Text="Ctrl+Shift+Tab"
                                                 Foreground="{StaticResource ReadOnlyInputForegroundBrush}"
                                                 Background="{StaticResource InputBackgroundBrush}"
                                                 BorderBrush="White"
                                                 BorderThickness="1"
                                                 Padding="8"/>

                                        <Button Grid.Column="1"
                                                Content="Set"
                                                Width="70"
                                                Height="32"
                                                Margin="8,0,0,0"
                                                Background="{StaticResource MainShellButtonBrush}"
                                                Style="{StaticResource RoundedButton}"
                                                Click="SetOverlayHotkey_Click"/>
                                    </Grid>

                                </StackPanel>

                            </Border>

                        </Grid>

                        <!-- ===== TOOLS VIEW ===== -->
                        <Grid x:Name="ToolsView"
      Visibility="Collapsed"
      Margin="24">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ================= LEFT: RESET MACRO + EXPLOSION ================= -->
                            <Border Grid.Column="0"
            Background="{StaticResource StrongPanelBackgroundBrush}"
            CornerRadius="12"
            Padding="16"
            Margin="0,0,12,0">

                                <StackPanel>

                                    <!-- ===== RESET MACRO HEADER ===== -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Reset Macro"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                                        <Button x:Name="ResetMacroToggleButton"
                        Grid.Column="1"
                        Width="138"
                        Height="38"
                        Margin="8,0,0,0"
                        Background="{StaticResource DangerRedBrush}"
                        Content="Disabled"
                        Style="{StaticResource ToggleActionButtonStyle}"
                        Click="ResetMacroToggleButton_Click"/>
                                    </Grid>

                                    <!-- HOTKEY -->
                                    <TextBlock Text="Hotkey"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="ResetHotkeyBox"
                         Height="32"
                         IsReadOnly="True"
                         Text="Not set"
                         Foreground="{StaticResource ReadOnlyInputForegroundBrush}"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="White"
                         BorderThickness="1"
                         Padding="8"/>

                                        <Button Grid.Column="1"
                        Content="Set"
                        Width="70"
                        Height="32"
                        Margin="8,0,0,0"
                        Background="{StaticResource MainShellButtonBrush}"
                        Style="{StaticResource RoundedButton}"
                        Click="SetResetHotkey_Click"/>
                                    </Grid>

                                    <!-- GAMEMODE -->
                                    <TextBlock Text="Gamemode"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

                                    <ComboBox x:Name="ResetGamemodeDropdown"
                      Style="{StaticResource MainDarkComboBox}"
                      SelectionChanged="ResetGamemodeDropdown_SelectionChanged">
                                        <ComboBoxItem Content="Survival"/>
                                        <ComboBoxItem Content="Hardcore"/>
                                        <ComboBoxItem Content="Creative"/>
                                        <ComboBoxItem Content="Freedom"/>
                                        <ComboBoxItem Content="SaveSlot1"/>
                                        <ComboBoxItem Content="SaveSlot2"/>
                                        <ComboBoxItem Content="SaveSlot3"/>
                                    </ComboBox>
                                    
                                    <TextBlock Text="Only Works on 1.00/default in-game UI scale."
           TextWrapping="Wrap"
           Margin="0,10,0,0"/>
                                    <!-- ===== SEPARATOR ===== -->
                                    <Border Height="1"
                    Background="{StaticResource SoftDividerBrush}"
                    Margin="0,10"/>

                                    <!-- ===== EXPLOSION RESET ===== -->
                                    <TextBlock Text="Reset Until Explosion"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

                                    <Button x:Name="ExplosionResetToggleButton"
                    Width="188"
                    Height="38"
                    Background="{StaticResource DangerRedBrush}"
                    Content="Disabled"
                    Style="{StaticResource ToggleActionButtonStyle}"
                    Click="ExplosionResetToggle_Click"/>

                                    <TextBlock Text="Explosion Time Window"
                       FontWeight="SemiBold"
                       Margin="0,12,0,4"/>

                                    <ComboBox x:Name="ExplosionPresetDropdown"
                      IsEnabled="False"
                      Style="{StaticResource MainDarkComboBox}"
                      SelectionChanged="ExplosionPresetDropdown_SelectionChanged">
                                        <ComboBoxItem Content="46:00 &#x2192; 46:30" Tag="Min46_To_4630"/>
                                        <ComboBoxItem Content="46:00 &#x2192; 47:00"  Tag="Min46_To_47"/>
                                        <ComboBoxItem Content="46:00 &#x2192; 48:00"  Tag="Min46_To_48"/>
                                        <ComboBoxItem Content="46:00 &#x2192; 50:00"  Tag="Min46_To_50"/>
                                        <ComboBoxItem Content="Under 1 Hour"   Tag="Under1Hour"/>
                                        <ComboBoxItem Content="Over 1 Hour"            Tag="Over1Hour"/>
                                    </ComboBox>

                                    <TextBlock Text="Subnautica only. Not available for Below Zero."
                                               TextWrapping="Wrap"
                                               Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- ================= RIGHT: TOOLS ================= -->
                            <Border Grid.Column="1"
            Background="{StaticResource PanelBackgroundBrush}"
            CornerRadius="12"
            Padding="16">

                                <StackPanel>
                                    <TextBlock Text="Hardcore Save Deleter"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Margin="0,0,0,12"/>

                                    <Button x:Name="HardcoreSaveDeleterToggleButton"
                                            Width="208"
                                            Height="38"
                                            Background="{StaticResource DangerRedBrush}"
                                            Content="Disabled"
                                            Style="{StaticResource ToggleActionButtonStyle}"
                                            Click="HardcoreSaveDeleterToggle_Click"/>

                                    <TextBlock Text="Deletes the latest Hardcore save after reset"
                                               TextWrapping="Wrap"
                                               Margin="0,12,0,0"/>
                                    <TextBlock Text="Only runs when Hardcore is selected"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>

                                    <Button x:Name="HardcoreSaveDeleterPurgeButton"
                                            Width="240"
                                            Height="32"
                                            Margin="0,10,0,0"
                                            Background="{StaticResource MainShellButtonBrush}"
                                            Content="Delete Hardcore Saves"
                                            Style="{StaticResource RoundedButton}"
                                            Click="HardcoreSaveDeleterPurge_Click"/>

                                    <Border Height="1"
                                            Background="{StaticResource SoftDividerBrush}"
                                            Margin="0,12,0,10"/>

                                    <TextBlock Text="Trackers and Timers"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Margin="0,0,0,12"/>

                                    <Button x:Name="Subnautica100TrackerCustomizeButton"
                                            Width="220"
                                            Height="32"
                                            Margin="0,0,0,0"
                                            Background="{StaticResource MainShellButtonBrush}"
                                            Content="Edit 100% Tracker"
                                            Style="{StaticResource RoundedButton}"
                                            Click="Subnautica100TrackerCustomize_Click"/>

                                    <Button x:Name="SpeedrunTimerCustomizeButton"
                                            Width="220"
                                            Height="32"
                                            Margin="0,8,0,0"
                                            Background="{StaticResource MainShellButtonBrush}"
                                            Content="Edit Speedrun Timer"
                                            Style="{StaticResource RoundedButton}"
                                            Click="SpeedrunTimerCustomize_Click"/>

                                    <TextBlock Text="Subnautica Only, Shows Run Progress through timer or Tracking for Speedruns"
                                               TextWrapping="Wrap"
                                               Margin="0,12,0,0"/>
                                </StackPanel>

                            </Border>

                        </Grid>

                        <!-- ===== INFO / UPDATES VIEW ===== -->
                        <Grid x:Name="InfoView"
      Visibility="Collapsed"
      Margin="24">

                            <Grid.RowDefinitions>
                                <!-- HEADER -->
                                <RowDefinition Height="Auto"/>

                                <!-- UPDATES LIST (SHORTER THAN BEFORE) -->
                                <RowDefinition Height="*"/>

                                <!-- FOOTER ICON BAR -->
                                <RowDefinition Height="64"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER (MOVED UP SLIGHTLY) -->
                            <TextBlock
        Grid.Row="0"
        Text="Launcher Info"
        HorizontalAlignment="Center"
        FontSize="26"
        FontWeight="UltraBold"
        Margin="-50,-6,0,8"/>

                            <!-- UPDATES CONTENT (MOVED UP + LESS BOTTOM SPACE) -->
                            <ScrollViewer
        Grid.Row="1"
        VerticalScrollBarVisibility="Hidden"
        Margin="0,0,0,8">

                                <Border
            Background="{StaticResource StrongPanelBackgroundBrush}"
            CornerRadius="14"
            Padding="14"
            Margin="0,0,8,0">

                                    <StackPanel x:Name="UpdatesPanel"/>

                                </Border>
                            </ScrollViewer>

                            <!-- FOOTER LINK BAR -->
                            <StackPanel
    Grid.Row="2"
    Orientation="Horizontal"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    Margin="0,6,0,0">

                                <!-- GitHub -->
                                <Button
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand"
        Margin="16,0"
        ToolTip="Open the launcher GitHub repository"
        Click="OpenGitHub_Click">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image
                Source="pack://application:,,,/Assets/Icons/GithubIcon.png"
                Width="32"
                Height="32"
                Margin="0,0,0,4"/>
                                        <TextBlock
                Text="Launcher GitHub"
                FontSize="12"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- YouTube -->
                                <Button
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand"
        Margin="16,0"
        ToolTip="Open the launcher YouTube channel"
        Click="OpenYouTube_Click">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image
                Source="pack://application:,,,/Assets/Icons/YoutubeIcon.png"
                Width="32"
                Height="32"
                Margin="0,0,0,4"/>
                                        <TextBlock
                Text="My YouTube"
                FontSize="12"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Discord -->
                                <Button
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand"
        Margin="16,0"
        ToolTip="Open the speedrun Discord"
        Click="OpenDiscord_Click">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image
                Source="pack://application:,,,/Assets/Icons/DiscordIcon.png"
                Width="32"
                Height="32"
                Margin="0,0,0,4"/>
                                        <TextBlock
                Text="Speedrun Discord"
                FontSize="12"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Viewbox>
    </Grid>
</Window>

<Window x:Class="SubnauticaLauncher.UI.EditVersionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="520"
        Height="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="{DynamicResource AppFontFamily}"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ImageBrush x:Key="BackgroundBrush"
                    Stretch="UniformToFill"/>

        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="25"
            ResizeBorderThickness="6"
            CornerRadius="0"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Rectangle Fill="{StaticResource BackgroundBrush}">
            <Rectangle.Effect>
                <BlurEffect Radius="8"/>
            </Rectangle.Effect>
        </Rectangle>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#40000000"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Source="pack://application:,,,/Assets/Icons/SNLIcon.png"
                       Width="16"
                       Height="16"
                       Margin="12,0,8,0"
                       VerticalAlignment="Center"/>

                <TextBlock x:Name="TitleBarText"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Margin="0,3,0,0"
                           FontWeight="SemiBold"/>

                <Button Grid.Column="2"
                        Content="&#x2715;"
                        Width="44"
                        Height="25"
                        Background="#8B2C2C"
                        BorderBrush="#55000000"
                        BorderThickness="1"
                        Click="Close_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>

            <Border Grid.Row="1"
                    Background="#90000000"
                    CornerRadius="14"
                    Padding="16"
                    Margin="16,12,16,16">
                <StackPanel>
                    <TextBlock Text="Display Name"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="DisplayNameBox"
                             MaxLength="25"
                             Margin="0,4,0,10"/>

                    <TextBlock Text="Folder Name"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="FolderNameBox"
                             Margin="0,4,0,6"/>

                    <TextBlock Text="Change folder name when adding the same version multiple times."
                               FontSize="11"
                               Foreground="#D0E7F2"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Launch Options"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="LaunchOptionsBox"
                             Margin="0,4,0,6"/>

                    <TextBlock Text="Use Game Launch Arguments, Recommended: -high -nosplash. These are only applied when the game launches without steam, as a replacement."
                               FontSize="11"
                               Foreground="#D0E7F2"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                    <Button x:Name="DetectSteamLaunchOptionsButton"
                            Content="Detect Steam Launch Options"
                            MinWidth="250"
                            Padding="18,0"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,16"
                            Background="{StaticResource DialogNeutralButtonBrush}"
                            Style="{StaticResource RoundedButton}"
                            Click="DetectSteamLaunchOptions_Click"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="Save"
                                Width="100"
                                Margin="0,0,10,0"
                                Background="#FF4FD38B"
                                Style="{StaticResource RoundedButton}"
                                Click="SaveRename_Click"/>

                        <Button Content="Delete"
                                Width="100"
                                Margin="0,0,10,0"
                                Background="#8B2C2C"
                                Style="{StaticResource RoundedButton}"
                                Click="Delete_Click"/>

                        <Button Content="Mods"
                                Width="100"
                                Margin="0,0,10,0"
                                Background="{StaticResource DialogNeutralButtonBrush}"
                                Style="{StaticResource RoundedButton}"
                                Click="Mods_Click"/>

                        <Button Content="Cancel"
                                Width="110"
                                Background="{StaticResource DialogNeutralButtonBrush}"
                                Style="{StaticResource RoundedButton}"
                                Click="Cancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
